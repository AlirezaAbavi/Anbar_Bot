# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Telegram
BOT_TOKEN=123456:your-token-from-BotFather
ADMIN_IDS=11111111,22222222          # telegram user ids auto-granted ADMIN on /start

# Inline-search result layout: "photo" = image gallery (works out of the box, no web server
# needed) | "article" = row with thumbnail + name + stock/price (needs PUBLIC_BASE_URL below).
INLINE_RESULT_STYLE=photo

# Public base URL of the web server, used to build photo URLs for inline-search thumbnails
# (only used when INLINE_RESULT_STYLE=article). Leave empty in dev; set your HTTPS host in prod:
# PUBLIC_BASE_URL=https://anbar.example.com

# Database
# Dev (default):
DATABASE_URL=sqlite:///db.sqlite3
# Production (MySQL, utf8mb4 required for Persian text + emoji):
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/anbar
