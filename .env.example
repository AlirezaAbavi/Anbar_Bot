# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Telegram
BOT_TOKEN=123456:your-token-from-BotFather
ADMIN_IDS=11111111,22222222          # telegram user ids auto-granted ADMIN on /start

# Update delivery mode: "polling" = `manage.py runbot` long-polls (default) | "webhook" = the
# Django web app receives Telegram's POSTs at /telegram/webhook/. Only one may be active.
BOT_MODE=polling
# Webhook mode only: shared secret Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token
# header; the webhook view rejects anything else. Leave empty for polling. Make it long+random:
# TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Inline-search result layout: "photo" = image gallery (works out of the box, no web server
# needed) | "article" = row with thumbnail + name + stock/price (needs PUBLIC_BASE_URL below).
INLINE_RESULT_STYLE=photo

# Public base URL of the web server. Used for inline-search thumbnails (INLINE_RESULT_STYLE=
# article) AND, in webhook mode, as the host Telegram POSTs to. Leave empty in dev; set your
# HTTPS host in prod:
# PUBLIC_BASE_URL=https://anbar.example.com

# Database
# Dev (default):
DATABASE_URL=sqlite:///db.sqlite3
# Production (MySQL, utf8mb4 required for Persian text + emoji):
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/anbar

# CI/CD deploy webhook (config/deploy.py). Only set on the server (PythonAnywhere).
# Leave empty in dev and the /deploy/ endpoint stays disabled.
# DEPLOY_SECRET must match the DEPLOY_SECRET GitHub Actions secret; make it long+random.
# DEPLOY_SECRET=change-me-to-a-long-random-string
# WSGI_RELOAD_PATH is the file to touch to reload the web app after a deploy:
# WSGI_RELOAD_PATH=/var/www/yourusername_pythonanywhere_com_wsgi.py

# CCE webhook inspector (config/cce.py). Optional signing secret used only to verify the
# X-CCE-Signature HMAC-SHA256 header for display; leave empty and requests are still captured.
# CCE_WEBHOOK_SECRET=whsec_...
